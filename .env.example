# LeanFM Website Environment Variables
# Copy this file to .env.local for local development

# Lead webhook URL - POST JSON to this endpoint on form submission
# Leave empty to log leads to console instead
LEAD_WEBHOOK_URL=

# Postgres connection string for Prisma/admin backend
DATABASE_URL=

# Admin session signing secret
ADMIN_SESSION_SECRET=

# Close CRM API key - if set, contact form submissions are sent to Close
CLOSE_API_KEY=

# Optional Close Lead Status ID for new website leads
CLOSE_LEAD_STATUS_ID=

# Optional Close Lead Status ID override for high-intent sample uploads
CLOSE_SAMPLE_UPLOAD_STATUS_ID=

# Optional Close API base URL override
CLOSE_API_BASE_URL=https://api.close.com/api/v1

# Optional sample intake webhook override
SAMPLE_INTAKE_WEBHOOK_URL=

# Sample intake object storage configuration
# If omitted, local disk storage is used for development uploads.
SAMPLE_UPLOAD_STORAGE_BUCKET=
SAMPLE_UPLOAD_STORAGE_REGION=us-east-1
SAMPLE_UPLOAD_STORAGE_ENDPOINT=
SAMPLE_UPLOAD_STORAGE_ACCESS_KEY_ID=
SAMPLE_UPLOAD_STORAGE_SECRET_ACCESS_KEY=
SAMPLE_UPLOAD_STORAGE_FORCE_PATH_STYLE=false

# Optional OnPoint intake endpoint for preview account provisioning
ONPOINT_SAMPLE_INTAKE_URL=

# Optional timeout for the OnPoint intake request in milliseconds
ONPOINT_SAMPLE_INTAKE_TIMEOUT_MS=15000

# Optional API key for the OnPoint intake endpoint
ONPOINT_API_KEY=

# Optional header name for the OnPoint API key
ONPOINT_API_KEY_HEADER=Authorization

# Authenticated callback from OnPoint back to the website admin mirror
ONPOINT_STATUS_WEBHOOK_TOKEN=
ONPOINT_STATUS_WEBHOOK_HEADER=x-leanfm-onpoint-webhook-key

# Sample intake draft persistence
SAMPLE_INTAKE_DRAFT_SECRET=
SAMPLE_INTAKE_ABANDONMENT_HOURS=24
SAMPLE_INTAKE_DRAFT_RETENTION_DAYS=90
SAMPLE_INTAKE_CRON_TOKEN=

# Optional Close Lead Status ID override for abandoned /start drafts
CLOSE_SAMPLE_INTAKE_DRAFT_STATUS_ID=

# Public site URL (used for meta tags and sitemap)
SITE_URL=https://leanfmtech.com

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
PLAUSIBLE_DOMAIN=

# Contact email displayed on site
CONTACT_EMAIL=info@leanfmtech.com

# App URL for "Try it free" button
APP_URL=https://app.leanfmtech.com
