generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  OPERATOR
}

enum LeadType {
  CONTACT
  SAMPLE_UPLOAD
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  SAMPLE_REVIEW_IN_PROGRESS
  CLOSED_WON
  CLOSED_LOST
}

enum LeadSyncStatus {
  SUCCESS
  FAILED
  PENDING_RETRY
}

enum SampleIntakeDraftStatus {
  ACTIVE
  ABANDONED
  COMPLETED
}

enum AuditAction {
  LOGIN
  LOGOUT
  LEAD_CREATED
  LEAD_STATUS_UPDATED
  LEAD_ASSIGNED
  LEAD_NOTE_CREATED
  LEAD_SYNC_RETRIED
  USER_CREATED
  USER_UPDATED
  SAMPLE_INTAKE_DRAFT_CREATED
  SAMPLE_INTAKE_DRAFT_ABANDONED
  SAMPLE_INTAKE_DRAFT_CLOSE_SYNCED
  SAMPLE_INTAKE_DRAFT_COMPLETED
}

model AdminUser {
  id                  String           @id @default(cuid())
  email               String           @unique
  passwordHash        String
  displayName         String
  role                AdminRole        @default(OPERATOR)
  isActive            Boolean          @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  sessions            Session[]
  notes               LeadNote[]
  audits              AuditLog[]
  currentAssigned     Lead[]           @relation("CurrentAssignee")
  assignmentTargets   LeadAssignment[] @relation("AssignmentTarget")
  assignmentActors    LeadAssignment[] @relation("AssignmentActor")
}

model Session {
  id          String    @id @default(cuid())
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model Lead {
  id                 String             @id @default(cuid())
  leadType           LeadType
  status             LeadStatus         @default(NEW)
  intent             String
  source             String
  name               String
  email              String
  company            String
  role               String?
  phone              String?
  buildingName       String?
  addressLine1       String?
  city               String?
  state              String?
  postalCode         String?
  buildingType       String?
  portfolioSize      String?
  message            String?
  submittedAt        DateTime           @default(now())
  currentAssigneeId  String?
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  qualificationNotes String?
  closeLeadId        String?
  closeContactId     String?
  lastSyncAt         DateTime?
  lastSyncError      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  currentAssignee    AdminUser?         @relation("CurrentAssignee", fields: [currentAssigneeId], references: [id], onDelete: SetNull)
  sampleIntakeAsset  SampleIntakeAsset?
  sourceDraft        SampleIntakeDraft?
  notes              LeadNote[]
  syncEvents         LeadSyncEvent[]
  assignmentHistory  LeadAssignment[]
  audits             AuditLog[]

  @@index([submittedAt])
  @@index([status])
  @@index([leadType])
  @@index([currentAssigneeId])
}

model SampleIntakeAsset {
  id                   String   @id @default(cuid())
  leadId               String   @unique
  submissionId         String
  basPlatform          String?
  primaryConcern       String?
  datasetFileName      String
  datasetFileSizeBytes Int
  datasetMimeType      String
  storageProvider      String?
  storageBucket        String?
  storageKey           String?
  storageRegion        String?
  storageEndpoint      String?
  localFilePath        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lead                 Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model SampleIntakeDraft {
  id                   String                  @id @default(cuid())
  status               SampleIntakeDraftStatus @default(ACTIVE)
  progressStep         Int                     @default(1)
  submissionId         String                  @unique
  draftTokenHash       String                  @unique
  name                 String?
  email                String?
  company              String?
  role                 String?
  phone                String?
  buildingName         String?
  addressLine1         String?
  city                 String?
  state                String?
  postalCode           String?
  buildingType         String?
  portfolioSize        String?
  basPlatform          String?
  primaryConcern       String?
  notes                String?
  datasetFileName      String?
  datasetFileSizeBytes Int?
  datasetMimeType      String?
  storageProvider      String?
  storageBucket        String?
  storageKey           String?
  storageRegion        String?
  storageEndpoint      String?
  localFilePath        String?
  closeLeadId          String?
  closeContactId       String?
  closeSyncStatus      LeadSyncStatus?
  closeSyncError       String?
  closeSyncedAt        DateTime?
  leadId               String?                 @unique
  lead                 Lead?                   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  lastSavedAt          DateTime                @default(now())
  abandonedAt          DateTime?
  completedAt          DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([status, lastSavedAt])
  @@index([email])
  @@index([closeSyncStatus])
  @@index([completedAt])
}

model LeadNote {
  id        String    @id @default(cuid())
  leadId     String
  authorId   String
  body       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author     AdminUser @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model LeadAssignment {
  id           String    @id @default(cuid())
  leadId        String
  assignedToId  String
  assignedById  String?
  createdAt     DateTime  @default(now())
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo    AdminUser @relation("AssignmentTarget", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy    AdminUser? @relation("AssignmentActor", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

model LeadSyncEvent {
  id                String         @id @default(cuid())
  leadId             String
  provider           String         @default("close")
  status             LeadSyncStatus
  externalLeadId     String?
  externalContactId  String?
  errorMessage       String?
  payload            Json?
  createdAt          DateTime       @default(now())
  lead               Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([status])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId      String?
  leadId       String?
  action       AuditAction
  entityType   String
  entityId     String
  description  String
  metadata     Json?
  createdAt    DateTime    @default(now())
  actor        AdminUser?  @relation(fields: [actorId], references: [id], onDelete: SetNull)
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([leadId])
  @@index([actorId])
}
